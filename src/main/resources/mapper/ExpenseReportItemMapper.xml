<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.buu.oa.mapper.ExpenseReportItemMapper">

    <!-- 按报销单ID查询明细列表 -->
    <select id="selectByReportId" resultType="com.buu.oa.entity.ExpenseReportItem">
        SELECT id, report_id, item_name, amount, expense_date, remark, create_time
        FROM expense_report_item
        WHERE report_id = #{reportId}
        ORDER BY id ASC
    </select>

    <!-- 按报销单ID删除所有明细 -->
    <delete id="deleteByReportId">
        DELETE FROM expense_report_item WHERE report_id = #{reportId}
    </delete>

</mapper>
